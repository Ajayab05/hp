# Local .terraform directories
**/.terraform/*

# Terraform state files
*.tfstate
*.tfstate.*

# Crash log files
crash.log

# Sensitive variable files
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Terraform lock file (optional)
# Keep this if you want reproducible builds
# .terraform.lock.hcl

# Plan files
*.tfplan

# Backend config files (if storing secrets)
backend.tf